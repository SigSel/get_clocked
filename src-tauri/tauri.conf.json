{
  "productName": "get-clocked",
  "version": "0.1.3",
  "identifier": "com.getclocked.app",
  "build": {
    "beforeDevCommand": "cd frontend && trunk serve",
    "beforeBuildCommand": "cd frontend && trunk build",
    "devUrl": "http://localhost:8080",
    "frontendDist": "../frontend/dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Get Clocked",
        "width": 900,
        "height": 600
      }
    ]
  }
}
